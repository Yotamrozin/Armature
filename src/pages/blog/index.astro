---
// Server-rendered for the same reason as the homepage: reads the draft-mode
// cookie per request and reflects published changes without a rebuild.
export const prerender = false;

import { loadQuery } from '../../lib/sanity/loadQuery';
import { getPerspectiveCookie } from '../../lib/sanity/draftMode';
import { postCardProjection, type PostCardData } from '../../lib/sanity/posts';
import PostCard from '../../components/PostCard.astro';
import { VisualEditing } from '@sanity/astro/visual-editing';

const perspective = getPerspectiveCookie(Astro.cookies);
const draftMode = Boolean(perspective);

const { data: posts } = await loadQuery<PostCardData[]>({
  query: `*[_type == "post" && defined(slug.current)] | order(publishedAt desc)${postCardProjection}`,
  perspective,
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Blog</title>
  </head>
  <body>
    <main class="blog-index">
      <h1 class="blog-index__heading">Blog</h1>
      {
        posts && posts.length > 0 ? (
          <div class="blog-index__grid">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
        ) : (
          <p class="blog-index__empty">
            No posts yet. Open the <a href="/admin">Studio</a> and publish one.
          </p>
        )
      }
    </main>

    <VisualEditing enabled={draftMode} />
  </body>
</html>

<style>
  body {
    font-family: system-ui, sans-serif;
    margin: 0;
    color: #111;
  }
  .blog-index {
    max-width: 64rem;
    margin-inline: auto;
    padding: 3rem 1.5rem;
  }
  .blog-index__heading {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin: 0 0 2rem;
  }
  .blog-index__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .blog-index__empty {
    color: #555;
  }
</style>
