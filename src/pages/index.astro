---
// Server-rendered so it can read the draft-mode cookie per request (visual
// editing). Published visits render on demand too, which means content updates
// appear without a rebuild.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { loadQuery } from '../lib/sanity/loadQuery';
import { getPerspectiveCookie } from '../lib/sanity/draftMode';
import { urlFor } from '../lib/sanity/image';
import { blockComponents } from '../lib/blocks';

const perspective = getPerspectiveCookie(Astro.cookies);

const { data: homepage } = await loadQuery<{
  heroHeading?: string;
  heroImage?: { alt?: string };
  sections?: { _type: string }[];
}>({
  query: `*[_id == "homepage"][0]{
    heroHeading,
    heroImage,
    sections[]{
      ...,
      _type,
      _type == "hero" => {
        cta{ ..., internal->{ _type, "slug": slug.current } }
      }
    }
  }`,
  perspective,
});

const heroImageUrl = homepage?.heroImage
  ? urlFor(homepage.heroImage).width(1600).height(900).fit('crop').url()
  : null;
---

<Layout title={homepage?.heroHeading ?? 'Armature'}>
  {
    homepage ? (
      <main>
        <section class="hero">
          {heroImageUrl && (
            <img class="hero__image" src={heroImageUrl} alt={homepage.heroImage?.alt ?? ''} />
          )}
          {homepage.heroHeading && <h1 class="hero__heading">{homepage.heroHeading}</h1>}
        </section>

        {(homepage.sections ?? []).map((section) => {
          const Block = blockComponents[section._type as keyof typeof blockComponents];
          return Block ? <Block block={section} perspective={perspective} /> : null;
        })}
      </main>
    ) : (
      <main class="empty">
        <h1>No homepage content yet</h1>
        <p>
          Open the <a href="/admin">Studio</a>, fill in the Homepage document, and publish.
        </p>
      </main>
    )
  }
</Layout>

<style>
  .hero {
    display: grid;
    gap: 1.5rem;
    padding: 4rem 1.5rem 2rem;
    max-width: 64rem;
    margin-inline: auto;
  }
  .hero__image {
    width: 100%;
    height: auto;
    border-radius: 0.75rem;
    object-fit: cover;
  }
  .hero__heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    margin: 0;
  }
  .empty {
    max-width: 40rem;
    margin: 6rem auto;
    padding: 0 1.5rem;
    text-align: center;
    color: #555;
  }
</style>
